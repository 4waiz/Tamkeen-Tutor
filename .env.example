
# AI provider ─ OPTIONAL.
# The app is fully usable without these: every AI route has a
# deterministic local fallback. Provide a key to enable AI mode.
#
# Works with any OpenAI-compatible Chat Completions endpoint
# (OpenAI, OpenRouter, Together, local LM servers, etc.).
AI_API_KEY=
# Base URL of the OpenAI-compatible API (no trailing slash).
AI_BASE_URL=https://api.openai.com/v1
# Model id to use for generation.
AI_MODEL=gpt-4o-mini

# Alias accepted for convenience - if AI_API_KEY is empty this is used.
OPENAI_API_KEY=
