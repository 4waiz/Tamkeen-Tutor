# ─────────────────────────────────────────────────────────────
# SkillCompass UAE — environment variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────

# Supabase ─ required for auth + persistence.
# Project Settings → API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-side only, NEVER prefixed NEXT_PUBLIC.
# Used by the mentor dashboard to aggregate across all learners.
# Optional: the mentor view falls back to the signed-in user's rows
# (via RLS) if this is absent.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider ─ OPTIONAL.
# The app is fully usable without these: every AI route has a
# deterministic local fallback. Provide a key to enable AI mode.
#
# Works with any OpenAI-compatible Chat Completions endpoint
# (OpenAI, OpenRouter, Together, local LM servers, etc.).
AI_API_KEY=
# Base URL of the OpenAI-compatible API (no trailing slash).
AI_BASE_URL=https://api.openai.com/v1
# Model id to use for generation.
AI_MODEL=gpt-4o-mini

# Alias accepted for convenience — if AI_API_KEY is empty this is used.
OPENAI_API_KEY=
